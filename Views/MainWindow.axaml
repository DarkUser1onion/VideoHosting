<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VideoHostingByWhoami.Model"
        x:Class="VideoHostingByWhoami.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Видеохостинг"
        Width="800" Height="450"
        Background="White">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="10" Orientation="Horizontal" Spacing="10">
            <TextBox PlaceholderText="Поиск..." Width="200" 
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
            <Button Content="Найти" />
        </StackPanel>

        <ScrollViewer>
            <ItemsControl Name="VideoListControl" Margin="10" ItemsSource="{Binding Videos}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:VideoItem">
                        <Border Background="LightGray" Width="200" Height="150" Margin="5" CornerRadius="8"
                                DoubleTapped="OnVideoDoubleTapped">
                            <StackPanel>
                                <Border Background="DarkGray" Height="100" CornerRadius="8">
                                    <TextBlock Text="[Превью]"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding Title}" Margin="5" FontWeight="Bold" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding FilePath}" FontSize="10" Margin="5" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>