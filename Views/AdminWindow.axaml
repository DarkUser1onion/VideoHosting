<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VideoHostingByWhoami.Views"
        x:Class="VideoHostingByWhoami.Views.AdminWindow"
        x:DataType="vm:AdminWindowViewModel"
        Title="Админ-панель"
        Width="520" Height="420"
        WindowStartupLocation="CenterOwner"
        Background="#030712"
        CanResize="False">

    <Window.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,8"/>
        </Style>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>
    </Window.Styles>

    <Border Classes="card" Margin="8" Padding="16">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="14">
            <TextBlock Text="Создание аккаунта модератора" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="Модератор сможет модерировать видео, но не получит доступ к админ-панели."
                       Foreground="#9CA3AF" TextWrapping="Wrap"/>

            <TextBlock Text="Логин" FontWeight="SemiBold"/>
            <TextBox Text="{Binding Login}" PlaceholderText="Введите логин модератора"/>

            <TextBlock Text="Пароль" FontWeight="SemiBold"/>
            <TextBox Text="{Binding Password}" PlaceholderText="Введите пароль" PasswordChar="●"/>

            <Button Content="Создать модератора"
                    Command="{Binding CreateModeratorCommand}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{Binding StatusColor}"
                       TextWrapping="Wrap"
                       IsVisible="{Binding HasStatus}"/>
        </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
