<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VideoHostingByWhoami.Model"
        x:Class="VideoHostingByWhoami.Views.ModerationWindow"
        x:DataType="vm:ModerationViewModel"
        x:Name="ModerationWnd"
        Title="Панель модерации"
        Width="1100" Height="750"
        WindowStartupLocation="CenterOwner"
        Background="#030712">

    <Window.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,8"/>
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#374151"/>
        </Style>
        <Style Selector="Button.approve">
            <Setter Property="Background" Value="#10B981"/>
        </Style>
        <Style Selector="Button.reject">
            <Setter Property="Background" Value="#EF4444"/>
        </Style>
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#DC2626"/>
        </Style>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>
        <Style Selector="TabControl">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TabItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,8"/>
        </Style>
    </Window.Styles>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="Панель модерации" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
        
        <TabControl Grid.Row="1">
            <!-- Вкладка модерации видео -->
            <TabItem Header="Видео на модерации">
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding PendingVideos}" Margin="0,10,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:VideoItem">
                                <Border Classes="card" Margin="0,0,0,16" Padding="16">
                                    <Grid ColumnDefinitions="200,*">
                                        <!-- Preview -->
                                        <Border Grid.Column="0" Background="#374151" CornerRadius="8" Height="120">
                                            <Image Source="{Binding PreviewImage}" Stretch="UniformToFill"/>
                                        </Border>
                                        
                                        <!-- Info -->
                                        <Grid Grid.Column="1" RowDefinitions="*,Auto" Margin="16,0,0,0">
                                            <StackPanel Grid.Row="0">
                                                <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding AuthorName}" Foreground="#9CA3AF" Margin="0,4,0,0"/>
                                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" 
                                                           MaxLines="2" Foreground="#9CA3AF" Margin="0,8,0,0"/>
                                                
                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                    <TextBlock Text="Категория:" Foreground="#6B7280" Margin="0,0,8,0"/>
                                                    <TextBlock Text="{Binding CategoryDisplay}"/>
                                                </StackPanel>
                                                
                                                <TextBlock Text="{Binding Status}" Foreground="#F59E0B" Margin="0,4,0,0"/>
                                            </StackPanel>
                                            
                                            <!-- Actions -->
                                            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,12,0,0">
                                                <Button Classes="secondary" Content="▶ Смотреть"
                                                        Command="{Binding $parent[Window].DataContext.PreviewCommand}"
                                                        CommandParameter="{Binding Id}"/>
                                                <Button Classes="approve" Content="✓ Одобрить"
                                                        Command="{Binding $parent[Window].DataContext.ApproveCommand}"
                                                        CommandParameter="{Binding Id}"/>
                                                <Button Classes="reject" Content="✕ Отклонить"
                                                        Command="{Binding $parent[Window].DataContext.RejectCommand}"
                                                        CommandParameter="{Binding Id}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>
            
            <!-- Вкладка управления пользователями -->
            <TabItem Header="Пользователи">
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding Users}" Margin="0,10,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:UserItem">
                                <Border Classes="card" Margin="0,0,0,8" Padding="16">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Login}" FontSize="16" FontWeight="SemiBold"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="Роль:" Foreground="#9CA3AF" Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding RoleDisplay}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding CreatedAt, StringFormat='Зарегистрирован: {0:dd.MM.yyyy}'}" 
                                                       Foreground="#9CA3AF" Margin="0,4,0,0" FontSize="12"/>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <Button Classes="danger" Content="Удалить"
                                                    Command="{Binding $parent[Window].DataContext.DeleteUserCommand}"
                                                    CommandParameter="{Binding Id}"
                                                    IsVisible="{Binding $parent[Window].DataContext.CanDeleteUsers}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
